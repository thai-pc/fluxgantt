{
  "name": "@fluxgantt/core",
  "version": "0.0.0",
  "description": "FluxGantt headless engine — state, compute, render, interaction, IO.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "devDependencies": {
    "@fluxgantt/eslint-config": "workspace:*",
    "@fluxgantt/tsconfig": "workspace:*",
    "@js-temporal/polyfill": "^0.5.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "@js-temporal/polyfill": "^0.5.1"
  },
  "peerDependenciesMeta": {
    "@js-temporal/polyfill": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
